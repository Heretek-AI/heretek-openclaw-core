# Browser Access Skill Configuration
# Copy this file to .env and customize for your environment

# ===========================================
# Browser Configuration
# ===========================================

# Run browser in headless mode (true/false)
BROWSER_HEADLESS=true

# Enable security sandbox (true/false)
BROWSER_SANDBOX=true

# Navigation timeout in milliseconds
BROWSER_TIMEOUT=30000

# Custom user agent string (optional, leave empty for default)
BROWSER_USER_AGENT=

# ===========================================
# Rate Limiting
# ===========================================

# Delay between requests in milliseconds
RATE_LIMIT_DELAY=1000

# Maximum requests per session
RATE_LIMIT_MAX_REQUESTS=100

# Add random jitter to delay (true/false)
RATE_LIMIT_RANDOMIZE=true

# ===========================================
# Security Settings
# ===========================================

# Block advertisements (true/false)
SECURITY_BLOCK_ADS=true

# Block tracking scripts (true/false)
SECURITY_BLOCK_TRACKERS=true

# Comma-separated list of allowed domains (empty = all allowed)
SECURITY_ALLOWED_DOMAINS=

# Comma-separated list of denied URL patterns (regex)
SECURITY_DENIED_PATTERNS=

# ===========================================
# Storage Directories
# ===========================================

# Directory for screenshots
SCREENSHOT_DIR=./skills/browser-access/screenshots

# Directory for PDF exports
PDF_DIR=./skills/browser-access/exports

# Directory for session storage
SESSION_DIR=./skills/browser-access/sessions

# ===========================================
# Privacy Settings
# ===========================================

# Accept cookies (true/false)
ACCEPT_COOKIES=false

# Clear cookies on browser close (true/false)
CLEAR_COOKIES_ON_CLOSE=true

# Block third-party cookies (true/false)
BLOCK_THIRD_PARTY_COOKIES=true

# ===========================================
# Resource Blocking
# ===========================================

# Comma-separated list of resource types to block
# Options: image, media, font, stylesheet, script, websocket, manifest, other
BLOCK_RESOURCES=image,media,font
